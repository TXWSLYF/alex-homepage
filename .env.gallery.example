# 复制为 .env.gallery 后填写（.env.gallery 已加入 .gitignore）

# 1) Cloudflare R2（S3 兼容 API）
R2_BUCKET=your-bucket-name
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_ENDPOINT=https://<accountId>.r2.cloudflarestorage.com

# 2) 浏览器可访问的公开 URL 前缀（无尾部斜杠）
# 例如自定义域名或 R2 公共开发域名：
#   https://pub-xxxx.r2.dev
# 生成 data/gallery.json 里的 thumbnailUrl / originalUrl 会拼在该前缀之后。
R2_PUBLIC_BASE_URL=https://<bucket>.<accountId>.r2.cloudflarestorage.com

# 3) 本地同步目录（相对仓库根目录）
#   originals/ 与 thumbs/1600w/ 与桶内 gallery/ 下结构一致
GALLERY_PHOTOS_DIR=./photos

# 4) 生成缩略图（npm run gallery:thumbs）时的最大宽度，默认 1600
#    使用 sharp：先按 EXIF 自动旋转像素，再缩放为 WebP，避免方向与网页原图不一致
GALLERY_THUMB_MAX_WIDTH=1600

# 5) gallery:build 会为每条目写入 ThumbHash（thumbHashBase64）到 data/gallery.json，
#    前端解码为 PNG data URL 作模糊占位，不增加额外静态文件。
